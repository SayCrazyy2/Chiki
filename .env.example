NODE_ENV=development
PORT=3000
HOST=0.0.0.0
LOG_LEVEL=info
TELEGRAM_BOT_TOKEN=replace_me
TELEGRAM_OWNER_ID=123456789
DATABASE_URL=postgresql://postgres:5432/chiki
WORKSPACE_DIR=/workspace
OPENAI_BASE_URL=https://api.openai.com/v1
